---
const navLinks = [
  { href: '/migration', label: 'Migration' },
  { href: '/species', label: 'Species' },
  { href: '/feeders', label: 'Feeders' },
  { href: '/nectar', label: 'Nectar' },
  { href: '/native-plants', label: 'Plants' },
  { href: '/seasonal-calendar', label: 'Calendar' },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-white/95 backdrop-blur-sm border-b border-mint-dark sticky top-0 z-50">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 text-emerald-brand font-heading font-bold text-xl hover:text-emerald-dark transition-colors">
        <img src="/images/hummingbird-logo-sm.png" alt="Southeast Hummingbirds" class="w-10 h-auto" width="40" height="20" />
        <span class="hidden sm:inline">Southeast Hummingbirds</span>
        <span class="sm:hidden">SE Hummingbirds</span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'px-3 py-2 rounded-lg text-sm font-medium transition-colors',
              currentPath === link.href || currentPath === link.href + '/'
                ? 'bg-mint text-emerald-brand'
                : 'text-navy hover:text-emerald-brand hover:bg-mint/50',
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg text-navy hover:bg-mint transition-colors"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" id="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg class="w-6 h-6 hidden" id="close-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Mobile Nav -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <div class="flex flex-col gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'px-3 py-2.5 rounded-lg text-sm font-medium transition-colors',
              currentPath === link.href || currentPath === link.href + '/'
                ? 'bg-mint text-emerald-brand'
                : 'text-navy hover:text-emerald-brand hover:bg-mint/50',
            ]}
          >
            {link.label}
          </a>
        ))}
        <div class="border-t border-mint-dark mt-2 pt-2 flex flex-col gap-1">
          <a href="/feeder-placement" class="px-3 py-2.5 rounded-lg text-sm text-navy hover:text-emerald-brand hover:bg-mint/50 transition-colors">Feeder Placement</a>
          <a href="/pest-control" class="px-3 py-2.5 rounded-lg text-sm text-navy hover:text-emerald-brand hover:bg-mint/50 transition-colors">Pest Control</a>
          <a href="/window-safety" class="px-3 py-2.5 rounded-lg text-sm text-navy hover:text-emerald-brand hover:bg-mint/50 transition-colors">Window Safety</a>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
  });
</script>
