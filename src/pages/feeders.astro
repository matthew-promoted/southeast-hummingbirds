---
import BaseLayout from '../layouts/BaseLayout.astro';
import { feeders, cleaningProtocol } from '../data/feeders';

const title = 'Best Hummingbird Feeders 2026 — Expert Reviews | Southeast Hummingbirds';
const description = 'Expert-tested hummingbird feeder recommendations at every price point. Ranked by ease of cleaning — the #1 factor in feeder selection.';

const schema = {
  '@context': 'https://schema.org',
  '@graph': feeders.map((feeder) => ({
    '@type': 'Product',
    name: feeder.name,
    description: feeder.whyRecommend,
    category: 'Hummingbird Feeders',
    brand: feeder.name.split(' ')[0],
    offers: {
      '@type': 'Offer',
      price: feeder.price,
      priceCurrency: 'USD',
      url: feeder.amazonUrl,
      availability: 'https://schema.org/InStock',
    },
    review: {
      '@type': 'Review',
      reviewRating: {
        '@type': 'Rating',
        ratingValue: feeder.cleaningEase,
        bestRating: 5,
        worstRating: 1,
      },
      author: {
        '@type': 'Organization',
        name: 'Southeast Hummingbirds',
      },
    },
  })),
};

const categoryColors: Record<string, { badge: string; border: string }> = {
  luxury: { badge: 'bg-emerald-brand text-white', border: 'border-emerald-brand/20' },
  basic: { badge: 'bg-blue-600 text-white', border: 'border-blue-200' },
  economy: { badge: 'bg-amber-500 text-white', border: 'border-amber-200' },
};

function renderStars(count: number): string[] {
  return Array.from({ length: 5 }, (_, i) => (i < count ? 'filled' : 'empty'));
}
---

<BaseLayout title={title} description={description} schema={schema}>
  <!-- Breadcrumbs -->
  <nav aria-label="Breadcrumb" class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-6">
    <ol class="flex items-center gap-2 text-sm text-gray-500">
      <li>
        <a href="/" class="hover:text-emerald-brand transition-colors">Home</a>
      </li>
      <li aria-hidden="true">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </li>
      <li>
        <span class="text-navy font-medium" aria-current="page">Best Feeders</span>
      </li>
    </ol>
  </nav>

  <!-- Page Header -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-12 md:pt-12 md:pb-16">
    <div class="max-w-3xl">
      <h1 class="text-navy font-heading">
        Best Hummingbird Feeders
        <span class="text-emerald-brand">2026</span>
      </h1>
      <p class="mt-4 text-lg text-gray-600 leading-relaxed">
        Expert-tested feeder recommendations at every price point, ranked by the factor that matters most.
      </p>
      <div class="mt-6 flex items-start gap-3 bg-mint border border-mint-dark rounded-xl p-4">
        <span class="flex-shrink-0 w-10 h-10 bg-emerald-brand/10 rounded-full flex items-center justify-center">
          <svg class="w-5 h-5 text-emerald-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </span>
        <div>
          <p class="font-semibold text-navy">Cleaning ease is the #1 selection criteria.</p>
          <p class="text-sm text-gray-600 mt-1">
            Nectar ferments quickly in warm southeastern summers. A feeder that's hard to clean is a feeder that won't get cleaned often enough, putting hummingbirds at risk of mold and bacteria.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Feeder Cards -->
  <section class="bg-mint py-12 md:py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {feeders.map((feeder) => {
          const colors = categoryColors[feeder.category];
          return (
            <article class={`bg-white border ${colors.border} rounded-2xl shadow-sm flex flex-col overflow-hidden`}>
              {/* Category Badge & Name */}
              <div class="p-6 pb-0">
                <span class={`inline-block text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full ${colors.badge}`}>
                  {feeder.categoryLabel}
                </span>
                <h2 class="mt-3 text-xl font-heading font-bold text-navy leading-tight">
                  {feeder.name}
                </h2>
              </div>

              {/* Quick Specs */}
              <div class="px-6 pt-4">
                <div class="grid grid-cols-3 gap-3 text-center">
                  <div class="bg-gray-50 rounded-lg py-2 px-1">
                    <div class="text-lg font-bold text-navy font-heading">{feeder.price}</div>
                    <div class="text-xs text-gray-500">Price</div>
                  </div>
                  <div class="bg-gray-50 rounded-lg py-2 px-1">
                    <div class="text-lg font-bold text-navy font-heading">{feeder.capacity}</div>
                    <div class="text-xs text-gray-500">Capacity</div>
                  </div>
                  <div class="bg-gray-50 rounded-lg py-2 px-1">
                    <div class="text-lg font-bold text-navy font-heading">{feeder.ports}</div>
                    <div class="text-xs text-gray-500">Ports</div>
                  </div>
                </div>
              </div>

              {/* Star Ratings */}
              <div class="px-6 pt-4">
                <div class="space-y-2">
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-gray-600">Cleaning Ease</span>
                    <div class="flex gap-0.5">
                      {renderStars(feeder.cleaningEase).map((star) => (
                        <svg class={`w-4 h-4 ${star === 'filled' ? 'text-amber-400' : 'text-gray-200'}`} fill="currentColor" viewBox="0 0 20 20">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                      ))}
                    </div>
                  </div>
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-gray-600">Durability</span>
                    <div class="flex gap-0.5">
                      {renderStars(feeder.durability).map((star) => (
                        <svg class={`w-4 h-4 ${star === 'filled' ? 'text-amber-400' : 'text-gray-200'}`} fill="currentColor" viewBox="0 0 20 20">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                      ))}
                    </div>
                  </div>
                </div>
              </div>

              {/* Feature Checklist */}
              <div class="px-6 pt-4">
                <div class="grid grid-cols-2 gap-x-4 gap-y-2 text-sm">
                  <div class="flex items-center gap-1.5">
                    {feeder.antMoat ? (
                      <svg class="w-4 h-4 text-emerald-brand flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                      </svg>
                    ) : (
                      <svg class="w-4 h-4 text-gray-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
                      </svg>
                    )}
                    <span class={feeder.antMoat ? 'text-gray-700' : 'text-gray-400'}>Ant moat</span>
                  </div>
                  <div class="flex items-center gap-1.5">
                    {feeder.beeGuards ? (
                      <svg class="w-4 h-4 text-emerald-brand flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                      </svg>
                    ) : (
                      <svg class="w-4 h-4 text-gray-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
                      </svg>
                    )}
                    <span class={feeder.beeGuards ? 'text-gray-700' : 'text-gray-400'}>Bee guards</span>
                  </div>
                  <div class="flex items-center gap-1.5">
                    {feeder.dishwasherSafe ? (
                      <svg class="w-4 h-4 text-emerald-brand flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                      </svg>
                    ) : (
                      <svg class="w-4 h-4 text-gray-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
                      </svg>
                    )}
                    <span class={feeder.dishwasherSafe ? 'text-gray-700' : 'text-gray-400'}>Dishwasher safe</span>
                  </div>
                  <div class="flex items-center gap-1.5">
                    {feeder.leakProof === 'yes' ? (
                      <svg class="w-4 h-4 text-emerald-brand flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                      </svg>
                    ) : (
                      <svg class="w-4 h-4 text-amber-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                    )}
                    <span class={feeder.leakProof === 'yes' ? 'text-gray-700' : 'text-gray-400'}>
                      {feeder.leakProof === 'yes' ? 'Leak-proof' : feeder.leakProof === 'mostly' ? 'Mostly leak-proof' : 'Can drip'}
                    </span>
                  </div>
                </div>
              </div>

              {/* Why We Recommend It */}
              <div class="px-6 pt-5">
                <h3 class="text-sm font-bold text-navy uppercase tracking-wider">Why we recommend it</h3>
                <p class="mt-2 text-sm text-gray-600 leading-relaxed">{feeder.whyRecommend}</p>
              </div>

              {/* Key Features */}
              <div class="px-6 pt-4">
                <h3 class="text-sm font-bold text-navy uppercase tracking-wider">Key Features</h3>
                <ul class="mt-2 space-y-1.5">
                  {feeder.keyFeatures.map((feature) => (
                    <li class="flex items-start gap-2 text-sm text-gray-600">
                      <svg class="w-4 h-4 text-emerald-brand flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>
              </div>

              {/* Considerations */}
              {feeder.considerations && feeder.considerations.length > 0 && (
                <div class="px-6 pt-4">
                  <h3 class="text-sm font-bold text-gray-500 uppercase tracking-wider">Considerations</h3>
                  <ul class="mt-2 space-y-1.5">
                    {feeder.considerations.map((consideration) => (
                      <li class="flex items-start gap-2 text-sm text-gray-500">
                        <svg class="w-4 h-4 text-amber-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <span>{consideration}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {/* Best For + CTA (pushed to bottom) */}
              <div class="mt-auto px-6 pt-5 pb-6 space-y-4">
                <div class="bg-emerald-50 border border-emerald-100 rounded-xl p-3">
                  <p class="text-sm">
                    <span class="font-bold text-emerald-brand">Best for:</span>
                    <span class="text-gray-700"> {feeder.bestFor}</span>
                  </p>
                </div>
                <a
                  href={feeder.amazonUrl}
                  target="_blank"
                  rel="noopener noreferrer nofollow"
                  class="flex items-center justify-center gap-2 w-full bg-emerald-brand hover:bg-emerald-dark text-white font-semibold py-3 px-4 rounded-xl transition-colors"
                >
                  View on Amazon
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Cleaning Protocol -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-navy font-heading">Cleaning Protocol</h2>
      <p class="mt-3 text-gray-600 text-lg">
        A clean feeder is a safe feeder. Follow this schedule to keep your hummingbirds healthy.
      </p>
    </div>

    <div class="mt-10 max-w-4xl mx-auto">
      <div class="overflow-x-auto rounded-2xl border border-gray-100 shadow-sm">
        <table class="w-full text-left">
          <thead>
            <tr class="bg-navy text-white">
              <th class="px-6 py-4 text-sm font-heading font-bold uppercase tracking-wider">Frequency</th>
              <th class="px-6 py-4 text-sm font-heading font-bold uppercase tracking-wider">Task</th>
              <th class="px-6 py-4 text-sm font-heading font-bold uppercase tracking-wider">Method</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {cleaningProtocol.map((step, i) => (
              <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                <td class="px-6 py-4 text-sm font-semibold text-navy whitespace-nowrap">{step.frequency}</td>
                <td class="px-6 py-4 text-sm text-gray-700">{step.task}</td>
                <td class="px-6 py-4 text-sm text-gray-600">{step.method}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Never Use -->
  <section class="bg-mint py-12 md:py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <div class="bg-white rounded-2xl border border-ruby/10 shadow-sm overflow-hidden">
          <div class="bg-ruby/5 border-b border-ruby/10 px-6 py-4">
            <h2 class="text-ruby font-heading text-xl flex items-center gap-2">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
              </svg>
              Never Use These to Clean Feeders
            </h2>
          </div>
          <div class="p-6">
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-ruby flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
                </svg>
                <div>
                  <span class="font-semibold text-navy">Dish soap</span>
                  <p class="text-sm text-gray-600 mt-0.5">Soap residue can harm hummingbirds, even in small amounts. Hot water and a brush are all you need.</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-ruby flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
                </svg>
                <div>
                  <span class="font-semibold text-navy">Scented cleaners</span>
                  <p class="text-sm text-gray-600 mt-0.5">Chemical fragrances leave residue and can deter birds from feeding.</p>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-ruby flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
                </svg>
                <div>
                  <span class="font-semibold text-navy">Abrasive scrubbers on plastic</span>
                  <p class="text-sm text-gray-600 mt-0.5">Scratches in plastic create grooves where bacteria and mold can hide and thrive.</p>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sources -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-navy font-heading text-xl">Sources</h2>
      <ul class="mt-4 space-y-2 text-sm text-gray-600">
        <li>
          <a href="https://nationalzoo.si.edu" target="_blank" rel="noopener noreferrer" class="text-emerald-brand hover:text-emerald-dark transition-colors underline">
            Smithsonian National Zoo
          </a> &mdash; Hummingbird feeder cleaning protocols
        </li>
        <li>
          <a href="https://bobvila.com/articles/best-hummingbird-feeders/" target="_blank" rel="noopener noreferrer" class="text-emerald-brand hover:text-emerald-dark transition-colors underline">
            Bob Vila
          </a> &mdash; Product testing and reviews
        </li>
        <li>
          <a href="https://thespruce.com/best-hummingbird-feeders" target="_blank" rel="noopener noreferrer" class="text-emerald-brand hover:text-emerald-dark transition-colors underline">
            The Spruce
          </a> &mdash; Expert feeder comparison and testing
        </li>
      </ul>
    </div>
  </section>
</BaseLayout>
