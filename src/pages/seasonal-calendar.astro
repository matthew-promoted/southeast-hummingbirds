---
import BaseLayout from '../layouts/BaseLayout.astro';
import { seasonalCalendar } from '../data/calendar';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Hummingbird Seasonal Calendar — Month by Month Guide',
  description: 'Month-by-month guide to hummingbird activity, feeding, and maintenance in the Southeast US.',
  author: {
    '@type': 'Organization',
    name: 'Southeast Hummingbirds',
  },
};

const currentMonth = new Date().toLocaleString('en-US', { month: 'long' });

const intensityConfig: Record<string, { label: string; bg: string; text: string; dot: string; border: string }> = {
  low: {
    label: 'Low Activity',
    bg: 'bg-gray-100',
    text: 'text-gray-600',
    dot: 'bg-gray-400',
    border: 'border-gray-200',
  },
  medium: {
    label: 'Moderate',
    bg: 'bg-blue-50',
    text: 'text-blue-700',
    dot: 'bg-blue-500',
    border: 'border-blue-200',
  },
  high: {
    label: 'High Activity',
    bg: 'bg-emerald-50',
    text: 'text-emerald-700',
    dot: 'bg-emerald-brand',
    border: 'border-emerald-200',
  },
  peak: {
    label: 'Peak Season',
    bg: 'bg-ruby/5',
    text: 'text-ruby',
    dot: 'bg-ruby',
    border: 'border-ruby/30',
  },
};

const sources = [
  { label: 'Hummingbird Central \u2014 Migration Map', url: 'https://www.hummingbirdcentral.com/hummingbird-migration-map.htm' },
  { label: 'Cornell Lab of Ornithology \u2014 Ruby-throated Hummingbird', url: 'https://www.allaboutbirds.org/guide/Ruby-throated_Hummingbird' },
  { label: 'Audubon \u2014 Hummingbird Guide', url: 'https://www.audubon.org/birds/hummingbirds' },
];
---

<BaseLayout
  title="Hummingbird Seasonal Calendar — Month by Month Guide | Southeast Hummingbirds"
  description="Month-by-month guide to hummingbird activity, feeding, and maintenance in the Southeast US."
  schema={schema}
>
  <!-- Breadcrumbs -->
  <nav aria-label="Breadcrumb" class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-6">
    <ol class="flex items-center gap-2 text-sm text-gray-500">
      <li>
        <a href="/" class="hover:text-emerald-brand transition-colors">Home</a>
      </li>
      <li aria-hidden="true">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </li>
      <li>
        <span class="text-navy font-medium">Seasonal Calendar</span>
      </li>
    </ol>
  </nav>

  <!-- Hero / Intro -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="max-w-3xl">
      <h1 class="text-navy font-heading">Hummingbird Seasonal Calendar</h1>
      <p class="mt-2 text-gray-500 text-lg">Month-by-month guide to activity, feeding, and maintenance in the Southeast US.</p>
    </div>

    <!-- Intensity Legend -->
    <div class="mt-8 flex flex-wrap gap-4">
      {Object.entries(intensityConfig).map(([key, config]) => (
        <div class="flex items-center gap-2 text-sm">
          <span class:list={['w-3 h-3 rounded-full', config.dot]} />
          <span class="text-gray-600">{config.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Calendar Grid -->
  <section class="bg-mint py-12 md:py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {seasonalCalendar.map((month) => {
          const isCurrent = month.month === currentMonth;
          const config = intensityConfig[month.intensity];
          return (
            <article
              class:list={[
                'rounded-2xl overflow-hidden transition-all',
                isCurrent
                  ? 'shadow-lg ring-2 ring-emerald-brand ring-offset-2 ring-offset-mint'
                  : 'shadow-sm',
                'bg-white border',
                isCurrent ? 'border-emerald-brand' : 'border-gray-100',
              ]}
            >
              <!-- Month Header -->
              <div
                class:list={[
                  'px-5 py-4 flex items-center justify-between',
                  isCurrent ? 'bg-emerald-brand' : 'bg-gray-50',
                ]}
              >
                <div class="flex items-center gap-3">
                  {isCurrent && (
                    <span class="w-2.5 h-2.5 bg-white rounded-full animate-pulse flex-shrink-0" />
                  )}
                  <h3
                    class:list={[
                      'font-heading font-bold text-xl',
                      isCurrent ? 'text-white' : 'text-navy',
                    ]}
                  >
                    {month.month}
                  </h3>
                </div>
                <span
                  class:list={[
                    'inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold',
                    isCurrent
                      ? 'bg-white/20 text-white'
                      : [config.bg, config.text],
                  ]}
                >
                  <span class:list={[
                    'w-1.5 h-1.5 rounded-full',
                    isCurrent ? 'bg-white' : config.dot,
                  ]} />
                  {config.label}
                </span>
              </div>

              <!-- Content -->
              <div class="p-5 space-y-4">
                <!-- Activity -->
                <div>
                  <span class="text-xs text-gray-400 uppercase tracking-wider font-medium">Activity</span>
                  <p class="mt-1 text-navy font-medium text-sm">{month.activity}</p>
                </div>

                <!-- Tasks -->
                <div>
                  <span class="text-xs text-gray-400 uppercase tracking-wider font-medium">What to Do</span>
                  <p class="mt-1 text-gray-600 text-sm leading-relaxed">{month.tasks}</p>
                </div>

                <!-- Intensity bar -->
                <div class="pt-2">
                  <div class="w-full bg-gray-100 rounded-full h-1.5 overflow-hidden">
                    <div
                      class:list={[
                        'h-full rounded-full transition-all',
                        month.intensity === 'low' ? 'w-1/4 bg-gray-400' : '',
                        month.intensity === 'medium' ? 'w-2/4 bg-blue-500' : '',
                        month.intensity === 'high' ? 'w-3/4 bg-emerald-brand' : '',
                        month.intensity === 'peak' ? 'w-full bg-ruby' : '',
                      ]}
                    />
                  </div>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Myth Buster -->
  <section class="py-12 md:py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="bg-ruby/5 border-2 border-ruby/20 rounded-2xl p-8 sm:p-10">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-12 h-12 bg-ruby rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
              </svg>
            </div>
            <div>
              <span class="text-ruby text-xs font-bold uppercase tracking-wider">Myth Buster</span>
              <h2 class="text-navy font-heading mt-1 text-xl sm:text-2xl">
                "Taking feeders down makes hummingbirds migrate"
              </h2>
            </div>
          </div>

          <div class="mt-6 flex items-center gap-3">
            <span class="bg-ruby text-white text-sm font-bold px-4 py-1.5 rounded-full uppercase tracking-wider">FALSE</span>
          </div>

          <div class="mt-5 space-y-4 text-gray-700 leading-relaxed">
            <p>
              This is one of the most persistent myths in backyard birding. Hummingbird migration is triggered by
              changes in daylight length (photoperiod), not by food availability. Birds have an internal biological
              clock that tells them when to migrate, regardless of how many feeders are available.
            </p>
            <p>
              Removing feeders early can actually harm late-migrating or struggling birds that depend on reliable food
              sources during their exhausting journey south. A hummingbird that is still visiting your feeder in late
              October is not "confused" &mdash; it is fueling up for a long flight and needs every calorie it can get.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tip: Keep Feeders Up -->
  <section class="bg-mint py-12 md:py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8 sm:p-10">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-12 h-12 bg-emerald-brand/10 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6 text-emerald-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h2 class="text-navy font-heading text-xl">When to Take Feeders Down</h2>
            </div>
          </div>
          <div class="mt-5 space-y-4 text-gray-700 leading-relaxed">
            <p>
              The general rule of thumb: keep your feeders up for at least <strong class="text-navy">two weeks after
              your last hummingbird sighting</strong>. This ensures any late stragglers, including rare western
              species like Rufous Hummingbirds that increasingly winter in the Southeast, have a food source.
            </p>
            <p>
              In coastal Georgia, Florida, and southern South Carolina, consider leaving one or two feeders up
              all winter. Overwintering hummingbirds are reported every year, and your feeder could be a
              lifeline during cold snaps.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sources -->
  <section class="py-12 md:py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-navy font-heading text-xl">Sources</h2>
      <ul class="mt-4 space-y-2">
        {sources.map((source) => (
          <li>
            <a
              href={source.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-emerald-brand hover:text-emerald-dark transition-colors text-sm underline underline-offset-2"
            >
              {source.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
