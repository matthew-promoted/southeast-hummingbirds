---
import BaseLayout from '../layouts/BaseLayout.astro';
import { species } from '../data/species';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Hummingbird Species Guide — Southeast US',
  description: 'Identify Ruby-throated Hummingbirds plus rare winter visitors like Rufous, Black-chinned, and Calliope Hummingbirds.',
  author: {
    '@type': 'Organization',
    name: 'Southeast Hummingbirds',
  },
};

const primarySpecies = species.find(s => s.isPrimary)!;
const rareSpecies = species.filter(s => !s.isPrimary);
---

<BaseLayout
  title="Hummingbird Species Guide — Southeast US | Southeast Hummingbirds"
  description="Identify Ruby-throated Hummingbirds plus rare winter visitors like Rufous, Black-chinned, and Calliope Hummingbirds."
  schema={schema}
>
  <!-- Breadcrumbs -->
  <nav aria-label="Breadcrumb" class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-6">
    <ol class="flex items-center gap-2 text-sm text-gray-500">
      <li>
        <a href="/" class="hover:text-emerald-brand transition-colors">Home</a>
      </li>
      <li aria-hidden="true">
        <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </li>
      <li>
        <span class="text-navy font-medium" aria-current="page">Species Guide</span>
      </li>
    </ol>
  </nav>

  <!-- Page Header -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-12 md:pt-12 md:pb-16">
    <div class="max-w-3xl">
      <h1 class="text-navy font-heading">
        Hummingbird Species Guide
      </h1>
      <p class="mt-4 text-lg md:text-xl text-gray-600 leading-relaxed">
        Learn to identify the hummingbirds you will encounter in the southeastern United States. From the
        common Ruby-throated Hummingbird to rare winter visitors, this guide covers field marks, seasonal
        timing, and key differences between species.
      </p>
    </div>
  </section>

  <!-- Primary Species: Ruby-throated -->
  <section class="bg-mint py-12 md:py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Species Header — 2-column on desktop: text + male photo -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8 items-start">
        <div>
          <div class="flex items-center gap-3 mb-2">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-emerald-brand text-white">
              Primary Species
            </span>
          </div>
          <h2 class="text-navy font-heading">{primarySpecies.name}</h2>
          <p class="mt-1 text-gray-500 italic">{primarySpecies.scientificName}</p>
          <p class="mt-3 text-gray-600 leading-relaxed">
            {primarySpecies.status}
          </p>
        </div>
        <figure class="bg-white rounded-2xl shadow-sm overflow-hidden">
          <img src="/images/photos/male-ruby-throated.jpg" alt="Adult male ruby-throated hummingbird in flight showing iridescent red gorget" class="w-full rounded-2xl" loading="lazy" />
          <figcaption class="text-xs text-gray-400 mt-2 mb-3 px-4">Photo: Joshua J. Cotten / Unsplash</figcaption>
        </figure>
      </div>

      <!-- Feature Tables -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Male -->
        {primarySpecies.features.male && (
          <div class="bg-white border border-gray-100 rounded-2xl shadow-sm overflow-hidden">
            <div class="bg-navy px-5 py-3.5">
              <h3 class="text-white font-heading text-lg flex items-center gap-2">
                <svg class="w-5 h-5 text-emerald-light" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-11a1 1 0 10-2 0v2H7a1 1 0 100 2h2v2a1 1 0 102 0v-2h2a1 1 0 100-2h-2V7z" clip-rule="evenodd" />
                </svg>
                Adult Male
              </h3>
            </div>
            <div class="divide-y divide-gray-50">
              {primarySpecies.features.male.map(f => (
                <div class="px-5 py-3.5">
                  <dt class="text-xs font-semibold text-emerald-brand uppercase tracking-wide">{f.feature}</dt>
                  <dd class="mt-1 text-sm text-gray-700 leading-relaxed">{f.description}</dd>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Female -->
        {primarySpecies.features.female && (
          <div class="bg-white border border-gray-100 rounded-2xl shadow-sm overflow-hidden">
            <div class="bg-navy px-5 py-3.5">
              <h3 class="text-white font-heading text-lg flex items-center gap-2">
                <svg class="w-5 h-5 text-ruby-light" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-11a1 1 0 10-2 0v2H7a1 1 0 100 2h2v2a1 1 0 102 0v-2h2a1 1 0 100-2h-2V7z" clip-rule="evenodd" />
                </svg>
                Adult Female
              </h3>
            </div>
            <figure class="px-4 pt-4">
              <img src="/images/photos/female-ruby-throated.jpg" alt="Female ruby-throated hummingbird perched on a branch showing white throat and green back" class="w-full rounded-xl" loading="lazy" />
              <figcaption class="text-xs text-gray-400 mt-1.5 mb-1">Photo: Annette Meredith / Unsplash</figcaption>
            </figure>
            <div class="divide-y divide-gray-50">
              {primarySpecies.features.female.map(f => (
                <div class="px-5 py-3.5">
                  <dt class="text-xs font-semibold text-emerald-brand uppercase tracking-wide">{f.feature}</dt>
                  <dd class="mt-1 text-sm text-gray-700 leading-relaxed">{f.description}</dd>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Juvenile -->
        {primarySpecies.features.juvenile && (
          <div class="bg-white border border-gray-100 rounded-2xl shadow-sm overflow-hidden">
            <div class="bg-navy px-5 py-3.5">
              <h3 class="text-white font-heading text-lg flex items-center gap-2">
                <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-11a1 1 0 10-2 0v2H7a1 1 0 100 2h2v2a1 1 0 102 0v-2h2a1 1 0 100-2h-2V7z" clip-rule="evenodd" />
                </svg>
                Juvenile
              </h3>
            </div>
            <div class="divide-y divide-gray-50">
              {primarySpecies.features.juvenile.map(f => (
                <div class="px-5 py-3.5">
                  <dt class="text-xs font-semibold text-emerald-brand uppercase tracking-wide">{f.feature}</dt>
                  <dd class="mt-1 text-sm text-gray-700 leading-relaxed">{f.description}</dd>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Key Difference -->
      {primarySpecies.keyDifference && (
        <div class="mt-8 bg-white border border-emerald-brand/20 rounded-2xl p-6">
          <div class="flex items-start gap-3">
            <span class="flex-shrink-0 mt-0.5 w-8 h-8 bg-emerald-brand/10 rounded-full flex items-center justify-center">
              <svg class="w-4 h-4 text-emerald-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </span>
            <div>
              <h4 class="font-heading font-bold text-navy">Quick ID Tip: Male vs. Female</h4>
              <p class="mt-1 text-sm text-gray-600 leading-relaxed">{primarySpecies.keyDifference}</p>
            </div>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Rare Winter Visitors -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="mb-8">
      <h2 class="text-navy font-heading">Rare Winter Visitors</h2>
      <p class="mt-3 text-gray-600 max-w-3xl leading-relaxed">
        While the Ruby-throated Hummingbird is the only breeding species in the eastern US, several western
        species occasionally overwinter in the Southeast, primarily from November through March. Keeping a
        feeder up through winter increases your chance of spotting one of these uncommon visitors.
      </p>
    </div>

    <figure class="mb-8 max-w-sm">
      <img src="/images/photos/rufous-hummingbird.jpg" alt="Rufous hummingbird showing distinctive orange-brown plumage" class="w-full rounded-2xl shadow-sm" loading="lazy" />
      <figcaption class="text-xs text-gray-400 mt-2">Photo: Unsplash photographer / Unsplash</figcaption>
    </figure>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {rareSpecies.map(sp => (
        <article class="bg-white border border-gray-100 rounded-2xl shadow-sm overflow-hidden flex flex-col">
          <!-- Card Header -->
          <div class="bg-gradient-to-r from-navy to-navy-light px-5 py-4">
            <div class="flex items-center gap-2 mb-1">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-ruby/20 text-ruby-light">
                Rare
              </span>
              {sp.whenToExpect && (
                <span class="text-xs text-white/60">{sp.whenToExpect}</span>
              )}
            </div>
            <h3 class="text-white font-heading text-lg">{sp.name}</h3>
            <p class="text-white/60 text-sm italic">{sp.scientificName}</p>
          </div>

          <!-- Card Body -->
          <div class="flex-1 p-5">
            <p class="text-sm text-gray-600 leading-relaxed">{sp.status}</p>

            {sp.likelihood && (
              <p class="mt-2 text-xs text-gray-500">
                <strong class="text-navy">Likelihood:</strong> {sp.likelihood}
              </p>
            )}

            <!-- Feature Lists -->
            <div class="mt-4 space-y-4">
              {sp.features.male && (
                <div>
                  <h4 class="text-xs font-semibold text-navy uppercase tracking-wide mb-2 flex items-center gap-1.5">
                    <span class="w-2 h-2 bg-emerald-brand rounded-full"></span>
                    Male
                  </h4>
                  <dl class="space-y-1.5">
                    {sp.features.male.map(f => (
                      <div class="flex gap-2 text-sm">
                        <dt class="font-medium text-gray-700 flex-shrink-0">{f.feature}:</dt>
                        <dd class="text-gray-600">{f.description}</dd>
                      </div>
                    ))}
                  </dl>
                </div>
              )}

              {sp.features.female && (
                <div>
                  <h4 class="text-xs font-semibold text-navy uppercase tracking-wide mb-2 flex items-center gap-1.5">
                    <span class="w-2 h-2 bg-ruby rounded-full"></span>
                    Female
                  </h4>
                  <dl class="space-y-1.5">
                    {sp.features.female.map(f => (
                      <div class="flex gap-2 text-sm">
                        <dt class="font-medium text-gray-700 flex-shrink-0">{f.feature}:</dt>
                        <dd class="text-gray-600">{f.description}</dd>
                      </div>
                    ))}
                  </dl>
                </div>
              )}
            </div>

            {sp.keyDifference && (
              <div class="mt-4 bg-mint rounded-xl p-3">
                <p class="text-xs text-gray-600 leading-relaxed">
                  <strong class="text-navy">Key difference:</strong> {sp.keyDifference}
                </p>
              </div>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Identification Tips -->
  <section class="bg-mint py-12 md:py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-navy font-heading mb-8">Key Identification Tips</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white border border-gray-100 rounded-2xl shadow-sm p-6">
          <div class="flex items-start gap-3">
            <span class="flex-shrink-0 w-10 h-10 bg-ruby/10 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5 text-ruby" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
            </span>
            <div>
              <h3 class="font-heading font-bold text-navy text-lg">Watch the Throat</h3>
              <p class="mt-2 text-sm text-gray-600 leading-relaxed">
                Gorget (throat patch) color is the most reliable identification feature for males. Ruby-throated shows
                red, Rufous shows orange-red, Black-chinned shows black with purple base, and Calliope shows magenta
                streaks rather than a solid patch. Gorgets can appear black in shade&mdash;wait for the bird to turn
                into direct sunlight.
              </p>
            </div>
          </div>
        </div>

        <div class="bg-white border border-gray-100 rounded-2xl shadow-sm p-6">
          <div class="flex items-start gap-3">
            <span class="flex-shrink-0 w-10 h-10 bg-amber-100 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </span>
            <div>
              <h3 class="font-heading font-bold text-navy text-lg">Consider the Season</h3>
              <p class="mt-2 text-sm text-gray-600 leading-relaxed">
                Timing narrows your options dramatically. From March through October, nearly every hummingbird in the
                Southeast is a Ruby-throat. A hummingbird at your feeder in December or January is almost certainly
                <em>not</em> a Ruby-throat&mdash;look carefully for Rufous, Black-chinned, or Calliope.
              </p>
            </div>
          </div>
        </div>

        <div class="bg-white border border-gray-100 rounded-2xl shadow-sm p-6">
          <div class="flex items-start gap-3">
            <span class="flex-shrink-0 w-10 h-10 bg-purple-100 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
              </svg>
            </span>
            <div>
              <h3 class="font-heading font-bold text-navy text-lg">Check the Size</h3>
              <p class="mt-2 text-sm text-gray-600 leading-relaxed">
                Calliope Hummingbirds are the smallest birds in North America&mdash;noticeably smaller than
                Ruby-throats. If a winter hummingbird at your feeder looks unusually tiny with a short tail that
                does not extend past folded wings, it may be a Calliope.
              </p>
            </div>
          </div>
        </div>

        <div class="bg-white border border-gray-100 rounded-2xl shadow-sm p-6">
          <div class="flex items-start gap-3">
            <span class="flex-shrink-0 w-10 h-10 bg-orange-100 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
              </svg>
            </span>
            <div>
              <h3 class="font-heading font-bold text-navy text-lg">Look for Rufous Tones</h3>
              <p class="mt-2 text-sm text-gray-600 leading-relaxed">
                Rufous Hummingbirds have distinctive warm orange-brown coloring on the back, flanks, and tail.
                No other Southeast hummingbird shows this much rufous. If you see a hummingbird with obvious
                orange or rust coloring, especially in winter, it is very likely a Rufous.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Report Sightings -->
      <div class="mt-8 bg-white border border-emerald-brand/20 rounded-2xl p-6">
        <div class="flex items-start gap-3">
          <span class="flex-shrink-0 w-10 h-10 bg-emerald-brand/10 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-emerald-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
            </svg>
          </span>
          <div>
            <h4 class="font-heading font-bold text-navy">Spotted a Rare Winter Visitor?</h4>
            <p class="mt-1 text-sm text-gray-600 leading-relaxed">
              If you think you have a non-Ruby-throated hummingbird visiting your feeder, report it to
              <a href="https://ebird.org" target="_blank" rel="noopener noreferrer" class="text-emerald-brand hover:text-emerald-dark font-medium underline decoration-emerald-brand/30 underline-offset-2 transition-colors">eBird</a>.
              Take photos and note the bird's size, tail shape, flank color, and gorget pattern. Your local
              Audubon chapter may be able to arrange a bander to confirm the identification.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Migration Link -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <a href="/migration" class="group block bg-white border border-gray-100 rounded-2xl shadow-sm p-6 hover:shadow-lg hover:border-emerald-200 transition-all">
        <span class="text-3xl">🗺️</span>
        <h3 class="mt-4 text-lg font-heading font-bold text-navy group-hover:text-emerald-brand transition-colors">
          Migration Timing
        </h3>
        <p class="mt-2 text-sm text-gray-600 leading-relaxed">
          Find out exactly when hummingbirds arrive and depart in your specific area of the Southeast.
        </p>
        <span class="inline-flex items-center gap-1 mt-4 text-sm font-medium text-emerald-brand group-hover:text-emerald-dark transition-colors">
          View migration data
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </span>
      </a>
      <a href="/seasonal-calendar" class="group block bg-white border border-gray-100 rounded-2xl shadow-sm p-6 hover:shadow-lg hover:border-emerald-200 transition-all">
        <span class="text-3xl">📅</span>
        <h3 class="mt-4 text-lg font-heading font-bold text-navy group-hover:text-emerald-brand transition-colors">
          Seasonal Calendar
        </h3>
        <p class="mt-2 text-sm text-gray-600 leading-relaxed">
          Month-by-month guide to feeding, cleaning, and what to watch for throughout the year.
        </p>
        <span class="inline-flex items-center gap-1 mt-4 text-sm font-medium text-emerald-brand group-hover:text-emerald-dark transition-colors">
          View calendar
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </span>
      </a>
    </div>
  </section>

  <!-- Sources -->
  <section class="bg-mint py-12 md:py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-navy font-heading text-xl mb-6">Sources</h2>
      <div class="bg-white border border-gray-100 rounded-2xl shadow-sm p-6">
        <ul class="space-y-3 text-sm text-gray-600">
          <li class="flex items-start gap-2">
            <span class="text-emerald-brand mt-0.5 font-bold">1.</span>
            <span>
              Cornell Lab of Ornithology. "Ruby-throated Hummingbird," "Rufous Hummingbird," "Black-chinned Hummingbird," "Calliope Hummingbird."
              <em>All About Birds.</em>
              <a href="https://www.allaboutbirds.org" target="_blank" rel="noopener noreferrer" class="text-emerald-brand hover:text-emerald-dark underline decoration-emerald-brand/30 underline-offset-2 transition-colors">allaboutbirds.org</a>
            </span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-emerald-brand mt-0.5 font-bold">2.</span>
            <span>
              Williamson, S. L. (2001). <em>A Field Guide to Hummingbirds of North America (Peterson Field Guides).</em> Houghton Mifflin.
            </span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-emerald-brand mt-0.5 font-bold">3.</span>
            <span>
              eBird. Species occurrence data for Georgia, Florida, South Carolina, and Alabama.
              <a href="https://ebird.org" target="_blank" rel="noopener noreferrer" class="text-emerald-brand hover:text-emerald-dark underline decoration-emerald-brand/30 underline-offset-2 transition-colors">ebird.org</a>
            </span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-emerald-brand mt-0.5 font-bold">4.</span>
            <span>
              Howell, S. N. G. (2002). <em>Hummingbirds of North America: The Photographic Guide.</em> Princeton University Press.
            </span>
          </li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
